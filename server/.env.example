# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys.

# --- Twilio (telephony) -------------------------------------------------------
# Hackathon-provided test creds — see hackathon organizers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- NVIDIA Nemotron (STT + LLM) — public hackathon endpoints -----------------
# From the README. No auth required.
NVIDIA_ASR_URL=ws://44.241.251.184:8080
NEMOTRON_LLM_URL=http://nemotron-fleet-alb-1322439314.us-west-2.elb.amazonaws.com/v1
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=false

# --- Gradium (TTS) — get a key at https://gradium.ai --------------------------
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# --- OpenAI fallback (only used if NEMOTRON_LLM_URL is unset) -----------------
OPENAI_API_KEY=

# --- Sam-specific -------------------------------------------------------------
# Local dev mode skips Krisp noise suppression filter.
ENV=local
# Where the SQLite DB lives. Default: server/sam/sam.db.
# SAM_DB_PATH=
